   "source": [
    "import numpy as np\n",
    "\n",
    "# Sample data\n",
    "x = [2, 4, 6, 8, 10]\n",
    "y = [1, 3, 5, 7, 9]\n",
    "\n",
    "# Covariance\n",
    "cov_matrix = np.cov(x, y)\n",
    "cov_xy = cov_matrix[0][1]\n",
    "\n",
    "# Correlation\n",
    "corr_matrix = np.corrcoef(x, y)\n",
    "corr_xy = corr_matrix[0][1]\n",
    "\n",
    "print(\"Covariance:\", cov_xy)\n",
    "print(\"Correlation:\", corr_xy)"
   ]
  },
